#!/bin/sh
# venice -- exec shim. Resolves $0 through symlinks to find the repo root,
# then runs `python3 -m venice`. All args forwarded.

set -eu

if command -v readlink >/dev/null 2>&1 && readlink -f / >/dev/null 2>&1; then
    SELF="$(readlink -f "$0")"
else
    SELF="$0"
    while [ -L "$SELF" ]; do
        DIR="$(cd "$(dirname "$SELF")" && pwd)"
        SELF="$(readlink "$SELF")"
        case "$SELF" in
            /*) ;;
            *) SELF="$DIR/$SELF" ;;
        esac
    done
    SELF="$(cd "$(dirname "$SELF")" && pwd)/$(basename "$SELF")"
fi

REPO_ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
export PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m venice "$@"
